# Channel bot tokens (required if channel is enabled)
DISCORD_BOT_TOKEN=your_discord_bot_token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Storage / health
DATABASE_URL=sqlite://data/orka-gateway.db
HEALTH_BIND=127.0.0.1:8787

# Operator policy
# ALLOWLIST examples: "discord:123456789,telegram:987654321"
ALLOWLIST=
OPEN_ACCESS=false

# Discord UX options
DISCORD_USE_EMBEDS=false

# Runtime defaults
DEFAULT_PROVIDER=claude
DEFAULT_RUNTIME_MODE=session
SESSION_FAIL_FALLBACK_EVENT=false

# Graceful shutdown drain timeout (ms)
SHUTDOWN_DRAIN_TIMEOUT_MS=10000

# Max concurrent pipeline tasks (default: 8)
MAX_CONCURRENT_TASKS=8

# Rate limiting (0 = disabled)
RATE_LIMIT_WINDOW_SECS=60
RATE_LIMIT_MAX_REQUESTS=0

# Runtime engine: echo | cli
RUNTIME_ENGINE=echo
PROVIDER_TIMEOUT_MS=90000
MAX_OUTPUT_BYTES=262144

# CLI runtime provider configs
# Args may be whitespace-separated text or JSON array string.
# Empty args use built-in defaults:
# - claude: -p --output-format json
# - codex: exec --json --skip-git-repo-check
# - opencode: run --format json
#
# Windows examples:
#   CLAUDE_BIN=C:/Users/YOU/AppData/Roaming/npm/claude.cmd
#   CODEX_BIN=C:/Users/YOU/orka/codex-wrapper.cmd
# Note: Use forward slashes (/) or double backslashes (\\) in paths.
# npm global installs create .cmd wrappers — use the .cmd path.
#
# Codex permission flags are ROOT-LEVEL options, not exec subcommand options.
# Use codex-wrapper.cmd (created by setup.ps1) to inject them:
#   codex-wrapper.cmd = codex --dangerously-bypass-approvals-and-sandbox %*
# Do NOT put --dangerously-bypass-approvals-and-sandbox in CODEX_EVENT_ARGS.
CLAUDE_BIN=
CLAUDE_EVENT_ARGS=
CLAUDE_SESSION_ARGS=

CODEX_BIN=
# On macOS, if `codex` shim fails with "Operation not permitted",
# set CODEX_BIN to the native codex binary path directly.
CODEX_EVENT_ARGS=
CODEX_SESSION_ARGS=

OPENCODE_BIN=
OPENCODE_EVENT_ARGS=
OPENCODE_SESSION_ARGS=
